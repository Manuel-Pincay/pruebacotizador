# Copiar a .env y ajustar (no commitear .env)

# ── Entorno ───────────────────────────────────────────────────
# development = MariaDB portable local (puerto 3307)
# production  = MySQL 8+ estable (Docker, VPS o servicio instalado)
ERP_ENV=development

ERP_SECRET_KEY=erp-dev-secret-change-in-production
ERP_SECRETADMIN_PASSWORD=203211
ERP_COOKIE_SECURE=false
ERP_SESSION_MAX_AGE=604800
ERP_ADMIN_SESSION_MAX_AGE=3600
ERP_PER_PAGE=20

# ── Base de datos ─────────────────────────────────────────────
# DESARROLLO (default si no se define DATABASE_URL):
# DATABASE_URL=mysql+pymysql://erp_user:erppassword@127.0.0.1:3307/erp?charset=utf8mb4

# PRODUCCIÓN (obligatorio con ERP_ENV=production):
# DATABASE_URL=mysql+pymysql://erp_user:STRONG_PASSWORD@127.0.0.1:3306/erp?charset=utf8mb4

# Docker Compose (servicio mysql en red interna):
# DATABASE_URL=mysql+pymysql://erp_user:erppassword@mysql:3306/erp?charset=utf8mb4

MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_PASSWORD=erppassword

DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_RECYCLE=3600
