# =============================================================================
# ERP — Variables de entorno
# =============================================================================
# 1. Copie este archivo a .env (no commitear .env):
#      Windows:  copy .env.example .env
#      Linux:    cp .env.example .env
# 2. Edite los valores marcados con [CAMBIAR]
# 3. Guía completa: docs/MYSQL_DEPLOYMENT.md
# =============================================================================

# ── Entorno ───────────────────────────────────────────────────────────────────
# development = pruebas local  |  production = servidor real
ERP_ENV=development

# ── Seguridad ─────────────────────────────────────────────────────────────────
# [CAMBIAR en producción] Clave para firmar cookies de sesión
# Generar: python -c "import secrets; print(secrets.token_hex(32))"
ERP_SECRET_KEY=erp-dev-secret-change-in-production

# [CAMBIAR en producción] Contraseña del panel /secretadmin
ERP_SECRETADMIN_PASSWORD=203211

# true = cookies solo por HTTPS (activar en producción con SSL/nginx)
ERP_COOKIE_SECURE=false

# Duración sesión usuario normal (segundos). Default: 7 días
ERP_SESSION_MAX_AGE=604800

# Duración sesión secretadmin (segundos). Default: 1 hora
ERP_ADMIN_SESSION_MAX_AGE=3600

# Registros por página en listados
ERP_PER_PAGE=20

# ── Base de datos MySQL ───────────────────────────────────────────────────────
# Formato: mysql+pymysql://USUARIO:CONTRASEÑA@HOST:PUERTO/BASE?charset=utf8mb4
#
# DESARROLLO (MySQL local, puerto 3306):
DATABASE_URL=mysql+pymysql://erp_user:erppassword@127.0.0.1:3306/erp?charset=utf8mb4
#
# PRODUCCIÓN (MySQL en servidor, puerto 3306) — descomente y ajuste:
# DATABASE_URL=mysql+pymysql://erp_user:SU_PASSWORD_FUERTE@127.0.0.1:3306/erp?charset=utf8mb4
#
# DOCKER COMPOSE (app dentro del contenedor, host = mysql):
# DATABASE_URL=mysql+pymysql://erp_user:SU_PASSWORD@mysql:3306/erp?charset=utf8mb4

# Pool de conexiones (solo MySQL)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_RECYCLE=3600

# ── Docker Compose (solo si usa docker compose up) ────────────────────────────
# [CAMBIAR en producción]
# MYSQL_ROOT_PASSWORD=rootpassword_seguro
# MYSQL_PASSWORD=password_erp_user_seguro


