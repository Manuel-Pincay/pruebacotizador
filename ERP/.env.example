# Copiar a .env y ajustar en el servidor (no commitear .env)

# development | production
ERP_ENV=development

# Clave para firmar cookies de sesión (generar una aleatoria en producción)
# python -c "import secrets; print(secrets.token_hex(32))"
ERP_SECRET_KEY=erp-dev-secret-change-in-production

# Contraseña panel /secretadmin (mismo valor que ya uses; no se cambia solo por ponerlo aquí)
ERP_SECRETADMIN_PASSWORD=203211

# Cookies solo HTTPS en producción (true si usas SSL)
ERP_COOKIE_SECURE=false

# Duración sesión usuario (segundos). Default: 7 días
ERP_SESSION_MAX_AGE=604800

# Duración sesión secretadmin (segundos). Default: 1 hora
ERP_ADMIN_SESSION_MAX_AGE=3600

# Registros por página en listados
ERP_PER_PAGE=20

# ── Base de datos ─────────────────────────────────────────────
# SQLite (desarrollo local)
DATABASE_URL=sqlite:///./database/innova.db

# MySQL 8+ (producción / staging)
# DATABASE_URL=mysql+pymysql://erp_user:STRONG_PASSWORD@127.0.0.1:3306/erp?charset=utf8mb4

# Pool de conexiones (solo MySQL)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_RECYCLE=3600
